{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/src-tauri/tauri.conf.json",
  "productName": "TitleForge",
  "version": "1.0.0",
  "identifier": "com.titleforge.desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "TitleForge",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; font-src 'self' https://api.fontshare.com; style-src 'self' 'unsafe-inline' https://api.fontshare.com; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "languages": ["English"],
        "startMenuFolder": "TitleForge"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "resources": ["../seed-data.json"]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "pubkey": "nMmbyRXVNON1KJT3yWIb0m/2xrfNFRPeZGrsRUEMk2I=",
      "endpoints": [
        "https://titleforge-tool.netlify.app/updates.json"
      ]
    }
  }
}
