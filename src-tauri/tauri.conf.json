{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/src-tauri/tauri.conf.json",
  "productName": "TitleSmith",
  "version": "1.0.0-beta.1",
  "identifier": "com.titlesmith.desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "TitleSmith",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "languages": ["English"],
        "startMenuFolder": "TitleForge"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "resources": ["../seed-data.json", "../models/SmolLM2-360M-Instruct-Q4_K_M.gguf", "../models/tokenizer.json"]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ3MjZBMTBGN0M5NEQyOTYKUldTVzBwUjhENkVtMXdITSt3eGNrOGMybkZtOVFvZHlrcTF4bnVPZnhjNzVsY1hDbG1BWkgxbGcK",
      "endpoints": [
        "https://github.com/Olammyinc/titlesmith-desktop/releases/latest/download/updates.json"
      ]
    }
  }
}
