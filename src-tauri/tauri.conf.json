{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/src-tauri/tauri.conf.json",
  "productName": "TitleForge Desktop",
  "version": "1.0.0",
  "identifier": "com.titleforge.desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "title": "TitleForge Desktop",
    "windows": [
      {
        "title": "TitleForge Desktop",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": null,
      "nsis": null
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": ""
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
